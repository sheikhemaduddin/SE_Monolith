{
  "name": "cloudways-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build:web": "npm run build --workspace=packages/web",
    "build:api": "npm run build --workspace=packages/api",
    "start:api": "npm run start --workspace=packages/api",
    "dev:web": "npm run dev --workspace=packages/web"
  },
  "engines": { "node": ">=18.0.0" }
}
